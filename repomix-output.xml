@import url('https://fonts.googleapis.com/css2?family=Crimson+Text:ital,wght@0,400;0,600;0,700;1,400&family=Klee+One:wght@400;600&display=swap');

@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  --paper:         #f2e8d0;
  --paper-dark:    #e6d8be;
  --paper-fold:    #cdbf9c;
  --ink:           #1e1208;
  --ink-fade:      #5c4228;
  --ink-light:     #8c6e4c;
  --forest:        #3a5c32;
  --amber:         #c87e18;
  --amber-light:   #e8a830;
  --ghibli-red:    #b83020;
  --sky:           #7aafcc;
  --cloud:         #ede6d8;
}

body {
  background-color: var(--paper);
  color: var(--ink);
  font-family: 'Crimson Text', serif;
  margin: 0;
  overflow-x: hidden;
  background-image: repeating-linear-gradient(
    transparent, transparent 27px,
    rgba(180, 140, 80, 0.07) 27px,
    rgba(180, 140, 80, 0.07) 28px
  );
}

.journal-ruled-container {
  position: relative;
}
.journal-ruled-container::before {
  content: '';
  position: absolute;
  top: 0;
  bottom: 0;
  left: 52px;
  width: 1px;
  background-color: rgba(184, 48, 32, 0.15);
  pointer-events: none;
  z-index: 10;
}

::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}
::-webkit-scrollbar-track {
  background: var(--paper-dark);
}
::-webkit-scrollbar-thumb {
  background: var(--paper-fold);
  border-radius: 4px;
}
::-webkit-scrollbar-thumb:hover {
  background: var(--ink-light);
}

@keyframes ghibliSteam {
  0% { opacity: 0; transform: translateY(2px) scaleX(0.9); }
  50% { opacity: 0.6; }
  100% { opacity: 0; transform: translateY(-10px) scaleX(1.1); }
}

@keyframes ghibliFloat {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-4px) rotate(1deg); }
}

@keyframes cloudDrift {
  0% { transform: translateX(-150px); }
  100% { transform: translateX(110vw); }
}

@keyframes fireflyFloat {
  0% { transform: translateY(0) translateX(0); opacity: 0; }
  10% { opacity: 0.8; }
  90% { opacity: 0.8; }
  100% { transform: translateY(-150px) translateX(30px); opacity: 0; }
}

@keyframes sootFall {
  0% { transform: translateY(-50px) translateX(0) rotate(0deg); opacity: 0; }
  15% { opacity: 0.9; }
  85% { opacity: 0.9; }
  100% { transform: translateY(105vh) translateX(50px) rotate(360deg); opacity: 0; }
}

.steam-line {
  animation: ghibliSteam 3s infinite ease-in-out;
}
.float-item {
  animation: ghibliFloat 5s infinite ease-in-out;
}
